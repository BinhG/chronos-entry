# Telegram Bot configuration
TELEGRAM_TOKEN="YOUR_TELEGRAM_BOT_TOKEN"
TELEGRAM_CHAT_ID="YOUR_CHAT_ID"

# Target symbol (Yahoo Finance ticker)
TARGET_SYMBOL="GC=F"

# Chronos model to load
MODEL_ID="amazon/chronos-2"

# How often (seconds) to auto-run forecast + push to Telegram
# Default: 14400 = every 4 hours
UPDATE_INTERVAL_SEC=14400
